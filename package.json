{
  "name": "caching_proxy_cli_tools_node",
  "version": "1.0.0",
  "description": "a CLI tool that starts a caching proxy server, it will forward requests to the actual server and cache the responses. If the same request is made again, it will return the cached response instead of forwarding the request to the server.",
  "main": "dist/index.js",
  "scripts": {
    "start": "ts-node src/index.ts",
    "build": "npx tsc",
    "docker-up": "docker compose -p caching-proxy -f docker/docker-compose.yml up -d",
    "docker-down": "docker compose -p caching-proxy -f docker/docker-compose.yml down",
    "docker-reset": "docker compose -p caching-proxy -f docker/docker-compose.yml down -v"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChinGuang/caching_proxy_cli_tools_node.git"
  },
  "keywords": [
    "cli",
    "tool"
  ],
  "author": "Gan Chin Guang",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/ChinGuang/caching_proxy_cli_tools_node/issues"
  },
  "homepage": "https://github.com/ChinGuang/caching_proxy_cli_tools_node#readme",
  "devDependencies": {
    "@types/node": "^25.3.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "bin": {
    "caching-proxy": "./bin/caching-proxy.sh"
  },
  "dependencies": {
    "redis": "^5.11.0"
  }
}
